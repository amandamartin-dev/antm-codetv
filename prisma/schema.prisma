generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum IssueStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CommentType {
  ISSUE
  PROJECT
}

enum NotificationType {
  MENTION
  ISSUE_ASSIGNED
  ISSUE_UPDATED
  GENERIC
}

model User {
  id             String           @id @default(cuid())
  clerkUserId    String           @unique
  email          String           @unique
  name           String
  role           Role             @default(MEMBER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  teamMemberships TeamMember[]
  projectMemberships ProjectMember[]
  leadProjects   Project[]        @relation("ProjectLead")
  assignedIssues Issue[]          @relation("IssueAssignee")
  issueComments  IssueComment[]   @relation("IssueCommentAuthor")
  projectComments ProjectComment[] @relation("ProjectCommentAuthor")
  notifications  Notification[]
  mentionedIn    CommentMention[] @relation("MentionedUser")
}

model Team {
  id        String       @id @default(cuid())
  key       String       @unique
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  members   TeamMember[]
  issues    Issue[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model Project {
  id          String          @id @default(cuid())
  key         String          @unique
  name        String
  description String?
  status      ProjectStatus   @default(PLANNED)
  leadUserId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lead        User?           @relation("ProjectLead", fields: [leadUserId], references: [id], onDelete: SetNull)
  members     ProjectMember[]
  releases    Release[]
  issues      Issue[]
  comments    ProjectComment[]
  mentions    CommentMention[] @relation("MentionedProject")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model Release {
  id        String    @id @default(cuid())
  projectId String
  name      String
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Label {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  issues    Issue[]
}

model Issue {
  id             String            @id @default(cuid())
  key            String            @unique
  title          String
  description    String?
  status         IssueStatus       @default(BACKLOG)
  priority       IssuePriority     @default(MEDIUM)
  dueDate        DateTime?
  teamId         String
  projectId      String?
  assigneeUserId String?
  labelId        String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  team           Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project        Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee       User?             @relation("IssueAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  label          Label?            @relation(fields: [labelId], references: [id], onDelete: SetNull)
  dependencies   IssueDependency[] @relation("IssueDependencyFrom")
  blockedBy      IssueDependency[] @relation("IssueDependencyTo")
  comments       IssueComment[]
  mentions       CommentMention[]  @relation("MentionedIssue")

  @@index([teamId])
  @@index([projectId])
  @@index([assigneeUserId])
}

model IssueDependency {
  id               String   @id @default(cuid())
  issueId          String
  blockedByIssueId String
  createdAt        DateTime @default(now())
  issue            Issue    @relation("IssueDependencyFrom", fields: [issueId], references: [id], onDelete: Cascade)
  blockedByIssue   Issue    @relation("IssueDependencyTo", fields: [blockedByIssueId], references: [id], onDelete: Cascade)

  @@unique([issueId, blockedByIssueId])
  @@index([blockedByIssueId])
}

model IssueComment {
  id           String   @id @default(cuid())
  issueId      String
  authorUserId String
  body         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  issue        Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author       User     @relation("IssueCommentAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([issueId])
}

model ProjectComment {
  id           String   @id @default(cuid())
  projectId    String
  authorUserId String
  body         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author       User     @relation("ProjectCommentAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model CommentMention {
  id               String      @id @default(cuid())
  commentType      CommentType
  commentId        String
  mentionedUserId  String?
  mentionedIssueId String?
  mentionedProjectId String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  mentionedUser    User?       @relation("MentionedUser", fields: [mentionedUserId], references: [id], onDelete: SetNull)
  mentionedIssue   Issue?      @relation("MentionedIssue", fields: [mentionedIssueId], references: [id], onDelete: SetNull)
  mentionedProject Project?    @relation("MentionedProject", fields: [mentionedProjectId], references: [id], onDelete: SetNull)

  @@index([commentType, commentId])
  @@index([mentionedUserId])
  @@index([mentionedIssueId])
  @@index([mentionedProjectId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  linkUrl   String
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}
